{
  "name": "davenport-files",
  "version": "0.2.0",
  "description": "Local-first asset manager for every program, every file type, every workflow.",
  "author": "D the Designer",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -n VITE,ELECTRON -c cyan,green \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "better-sqlite3": "^9.4.3",
    "sharp": "^0.33.3",
    "archiver": "^7.0.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.1.4",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.davenport-files.app",
    "productName": "Davenport Files",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "package.json"],
    "asar": true,
    "asarUnpack": ["node_modules/better-sqlite3/**/*", "node_modules/sharp/**/*"],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "linux": { "target": [{ "target": "AppImage", "arch": ["x64"] }] },
    "publish": { "provider": "github", "releaseType": "release" }
  }
}
